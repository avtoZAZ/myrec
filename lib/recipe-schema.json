{
  "title": "RecipeImportPayload",
  "oneOf": [
    {
      "$ref": "#/$defs/single"
    },
    {
      "type": "object",
      "required": [
        "recipes"
      ],
      "properties": {
        "recipes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/recipe"
          }
        },
        "publish": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  ],
  "$defs": {
    "single": {
      "allOf": [
        {
          "$ref": "#/$defs/recipe"
        },
        {
          "type": "object",
          "properties": {
            "publish": {
              "type": "boolean"
            }
          }
        }
      ]
    },
    "recipe": {
      "type": "object",
      "required": [
        "id",
        "title",
        "slug",
        "description",
        "coverImage",
        "category",
        "difficulty",
        "ingredients",
        "steps"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 3
        },
        "title": {
          "type": "string",
          "minLength": 2
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "description": {
          "type": "string",
          "minLength": 10
        },
        "coverImage": {
          "type": "string"
        },
        "gallery": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "category": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "difficulty": {
          "enum": [
            "easy",
            "medium",
            "hard"
          ]
        },
        "prepTimeMinutes": {
          "type": "integer",
          "minimum": 0
        },
        "cookTimeMinutes": {
          "type": "integer",
          "minimum": 0
        },
        "totalTimeMinutes": {
          "type": "integer",
          "minimum": 0
        },
        "servings": {
          "type": "integer",
          "minimum": 1
        },
        "published": {
          "type": "boolean"
        },
        "featured": {
          "type": "boolean"
        },
        "ingredients": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "amount": {
                "type": "number"
              },
              "unit": {
                "type": "string"
              },
              "note": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "title",
              "description"
            ],
            "properties": {
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "image": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nutrition": {
          "type": "object",
          "properties": {
            "calories": {
              "type": "number"
            },
            "protein": {
              "type": "number"
            },
            "fat": {
              "type": "number"
            },
            "carbs": {
              "type": "number"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}