generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Recipe {
  id               String   @id
  title            String
  slug             String   @unique
  description      String
  coverImage       String
  gallery          Json
  category         String
  tags             Json
  difficulty       String
  prepTimeMinutes  Int
  cookTimeMinutes  Int
  totalTimeMinutes Int
  servings         Int
  published        Boolean  @default(false)
  featured         Boolean  @default(false)
  ingredients      Json
  steps            Json
  notes            Json
  nutrition        Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
